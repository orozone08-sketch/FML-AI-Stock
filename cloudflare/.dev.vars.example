# Copy to .dev.vars. Never commit .dev.vars or production credentials.
APP_ENV=development
SESSION_HMAC_KEY=replace-with-at-least-32-random-bytes
CSRF_HMAC_KEY=replace-with-a-different-random-secret
REGISTRATION_INVITE_KEY=replace-with-a-long-random-registration-invite
LOCAL_SEED_ADMIN_EMAIL=admin@local.invalid
LOCAL_SEED_ADMIN_PASSWORD=local-only-change-me
